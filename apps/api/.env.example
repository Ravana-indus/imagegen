DATABASE_URL=postgresql+psycopg://<db-user>:<db-password>@<supabase-pooler-host>:6543/postgres
SUPABASE_URL=https://qukjfjpevpjzctrtfuse.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key
STORAGE_BUCKET=editimage
# Use "supabase" when Qwen should receive signed Supabase Storage URLs.
STORAGE_BACKEND=supabase

SESSION_SECRET=your-session-secret-key
# Keep true in hosted HTTPS environments; use false only for local HTTP testing.
SESSION_COOKIE_SECURE=true
REDIS_URL=redis://127.0.0.1:6379/0

DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_MODEL=qwen-image-2.0-pro
# qwen-image-2.0-pro international submissions are gated at two per minute.
DASHSCOPE_MIN_INTERVAL_SECONDS=31
SIGNED_URL_TTL_SECONDS=900
